DATABASE_URL="postgresql://postgres:postgres@localhost:5432/designer_kicks"
# Password for /admin — change this before going live
ADMIN_PASSWORD="heatcheck"
# Optional: get an email heads-up when applications, submissions, or sales come in
ADMIN_EMAIL=""
# Second admin lock: comma-separated member emails allowed into /admin.
# When set, admin requires being signed in as one of these accounts AND
# the password. Set it to your own login email in production.
ADMIN_EMAILS=""
# Public URL of the deployed site — used for SEO tags, sitemap, and RSS
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Auth (required) — generate with: openssl rand -base64 32
AUTH_SECRET="X1UGcan4uxIZfINeLx9+JptV1p2zao6KdWvM2AiT_mE="

# OAuth sign-in (optional — buttons appear when set)
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Facebook: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Password reset emails via https://resend.com (optional — dev mode shows link on screen)
RESEND_API_KEY=""
EMAIL_FROM="The Heat Chart <noreply@theheatchart.com>"

# Store Scout (beta, admin-only): Google Places API (New) key for
# scanning shoe stores around a zip code. Optional — the board still
# works with hand-added stores when unset.
GOOGLE_PLACES_API_KEY=""

# Affiliate tags for the /go outbound layer (all optional — links work
# untagged until these are set). Two template styles:
#   "&param=value"  -> appended to the target URL (eBay-style)
#   "https://...{url}" -> replaces the link entirely; {url} = encoded
#                          target (Impact/Sovrn-style deep links)
AFF_EBAY_TEMPLATE=""        # e.g. "&mkcid=1&mkrid=711-53200-19255-0&campid=YOURCAMPID&toolid=10001"
AFF_STOCKX_TEMPLATE=""      # e.g. "https://stockx.pxf.io/c/YOURID/YOURPROG/9060?u={url}"
AFF_GOAT_TEMPLATE=""
AFF_KICKSCREW_TEMPLATE=""
AFF_FLIGHTCLUB_TEMPLATE=""
AFF_FOOTLOCKER_TEMPLATE=""
AFF_JDSPORTS_TEMPLATE=""
AFF_END_TEMPLATE=""
AFF_AMAZON_TEMPLATE=""      # e.g. "&tag=yourtag-20"
AFF_ANGELUS_TEMPLATE=""
AFF_RESHOEVN8R_TEMPLATE=""
AFF_CREP_TEMPLATE=""
AFF_JASONMARKK_TEMPLATE=""
AFF_LACELAB_TEMPLATE=""
AFF_UNDEFEATED_TEMPLATE=""

# Stripe for quiz credit packs (optional — dev purchase button appears when unset)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Object storage for uploads (optional — local disk used when unset)
# Works with Cloudflare R2, AWS S3, Supabase Storage, Backblaze B2
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""
# Endpoint required for R2/Supabase/B2 (leave blank for AWS S3)
S3_ENDPOINT=""
S3_REGION="auto"

# Protects /api/cron/finalize (Vercel sends it automatically as a bearer token)
CRON_SECRET=""

# Optional privacy-friendly analytics — set to your domain to enable Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# Set to "true" ONLY in local/test environments: allows free credit-pack
# grants when Stripe is unconfigured. NEVER set in production — without it,
# a Stripe-less launch shows "packs coming soon" instead of free credits.
PAYMENTS_DEV_MODE=""
