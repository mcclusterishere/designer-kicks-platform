DATABASE_URL="postgresql://postgres:postgres@localhost:5432/designer_kicks"
# Password for /admin — change this before going live
ADMIN_PASSWORD="heatcheck"
# Public URL of the deployed site — used for SEO tags, sitemap, and RSS
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Auth (required) — generate with: openssl rand -base64 32
AUTH_SECRET="X1UGcan4uxIZfINeLx9+JptV1p2zao6KdWvM2AiT_mE="

# OAuth sign-in (optional — buttons appear when set)
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Facebook: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Password reset emails via https://resend.com (optional — dev mode shows link on screen)
RESEND_API_KEY=""
EMAIL_FROM="The Heat Chart <noreply@theheatchart.com>"

# Stripe for quiz credit packs (optional — dev purchase button appears when unset)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Object storage for uploads (optional — local disk used when unset)
# Works with Cloudflare R2, AWS S3, Supabase Storage, Backblaze B2
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""
# Endpoint required for R2/Supabase/B2 (leave blank for AWS S3)
S3_ENDPOINT=""
S3_REGION="auto"

# Protects /api/cron/finalize (Vercel sends it automatically as a bearer token)
CRON_SECRET=""

# Optional privacy-friendly analytics — set to your domain to enable Plausible
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# Set to "true" ONLY in local/test environments: allows free credit-pack
# grants when Stripe is unconfigured. NEVER set in production — without it,
# a Stripe-less launch shows "packs coming soon" instead of free credits.
PAYMENTS_DEV_MODE=""
