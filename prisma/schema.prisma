generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Submission {
  id           String   @id @default(cuid())
  title        String
  artistName   String // denormalized from the artist profile at submit time
  socialHandle String?
  email        String
  baseShoe     String
  description  String?
  imageUrl     String
  status       String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt    DateTime @default(now())

  artistId String?
  artist   ArtistProfile? @relation(fields: [artistId], references: [id], onDelete: SetNull)

  battlesAsA Battle[] @relation("battleSubA")
  battlesAsB Battle[] @relation("battleSubB")
  battlesWon Battle[] @relation("battleWinner")
  votes      Vote[]
}

model ArtistProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String   @unique
  displayName String
  bio         String?
  instagram   String?
  city        String?
  createdAt   DateTime @default(now())

  submissions Submission[]
  followers   ArtistFollow[]
}

model ArtistFollow {
  id        String   @id @default(cuid())
  artistId  String
  artist    ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([artistId, userId])
}

model Battle {
  id       String    @id @default(cuid())
  title    String?
  status   String    @default("ACTIVE") // ACTIVE | COMPLETED
  startsAt DateTime  @default(now())
  endsAt   DateTime
  createdAt DateTime @default(now())

  subAId String
  subA   Submission @relation("battleSubA", fields: [subAId], references: [id])
  subBId String
  subB   Submission @relation("battleSubB", fields: [subBId], references: [id])

  winnerId String?
  winner   Submission? @relation("battleWinner", fields: [winnerId], references: [id])

  votes Vote[]
}

model Vote {
  id           String   @id @default(cuid())
  battleId     String
  battle       Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  voterKey     String // the voting user's id (or a seed key for demo votes)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@unique([battleId, voterKey])
  @@index([battleId, submissionId])
}

// ---------- Accounts & auth (NextAuth models + profile fields) ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for OAuth-only accounts

  // Profile / contact info
  phone              String?
  city               String?
  shoeSize           String?
  favoriteSilhouette String?
  instagram          String?
  marketingOptIn     Boolean @default(false)

  // Quiz economy
  credits         Int     @default(0) // purchased strikes
  freeStrikesDate String? // YYYY-MM-DD the free-strike counter applies to
  freeStrikesUsed Int     @default(0)

  createdAt DateTime @default(now())

  accounts       Account[]
  sessions       Session[]
  votes          Vote[]
  quizRuns       QuizRun[]
  creditTxns     CreditTransaction[]
  giveawayEntries GiveawayEntry[]
  giveawaysWon   Giveaway[]          @relation("giveawayWinner")
  artistProfile  ArtistProfile?
  artistFollows  ArtistFollow[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PasswordResetToken {
  token     String   @id
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())
}

// ---------- Quiz game & giveaway ----------

model QuizQuestion {
  id          String  @id @default(cuid())
  question    String
  options     String // JSON array of 4 strings
  answerIndex Int
  difficulty  Int     @default(1) // 1 easy, 2 medium, 3 hard
  category    String  @default("history")
  explanation String?
  active      Boolean @default(true)
  createdAt   DateTime @default(now())
}

model QuizRun {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionIds  String // JSON array, server-chosen order
  currentIndex Int       @default(0)
  correctCount Int       @default(0)
  wrongCount   Int       @default(0)
  status       String    @default("ACTIVE") // ACTIVE | NEEDS_CREDITS | WON | ABANDONED
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
}

model CreditTransaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta           Int
  reason          String // purchase | strike | admin
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())
}

model Giveaway {
  id          String   @id @default(cuid())
  title       String
  prize       String
  description String?
  endsAt      DateTime
  status      String   @default("ACTIVE") // ACTIVE | DRAWN | CLOSED
  winnerId    String?
  winner      User?    @relation("giveawayWinner", fields: [winnerId], references: [id])
  createdAt   DateTime @default(now())

  entries GiveawayEntry[]
}

model GiveawayEntry {
  id         String   @id @default(cuid())
  giveawayId String
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source     String   @default("quiz") // quiz | manual
  createdAt  DateTime @default(now())
}

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String // doubles as the meta description — keep under ~160 chars
  content     String // markdown
  coverImage  String?
  tags        String? // comma-separated
  status      String    @default("DRAFT") // DRAFT | PUBLISHED
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id           String  @id @default(cuid())
  name         String
  merchant     String
  category     String // marketplace | retail | customization | cleaning | accessories
  blurb        String?
  price        String?
  imageUrl     String?
  affiliateUrl String
  featured     Boolean @default(false)
  sortOrder    Int     @default(0)
  createdAt    DateTime @default(now())
}
