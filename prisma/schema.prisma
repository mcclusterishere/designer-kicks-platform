generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id           String   @id @default(cuid())
  title        String
  artistName   String // denormalized from the artist profile at submit time
  socialHandle String?
  email        String
  baseShoe     String
  // Taxonomy under the custom — powers the taste engine. brand is the
  // maker (Jordan, Nike), silhouette the model (Air Jordan 11), and
  // baseColorway what the donor pair looked like before the work.
  brand        String?
  silhouette   String?
  baseColorway String?
  description  String?
  imageUrl     String
  status       String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt    DateTime @default(now())

  // Gallery beyond the cover shot — voters swipe through these inline.
  extraImages String[] @default([])

  artistId String?
  artist   ArtistProfile? @relation(fields: [artistId], references: [id], onDelete: SetNull)

  // Provenance: set when the one-of-one is sold/transferred to a fan.
  ownerId String?
  owner   User?   @relation("ownedPieces", fields: [ownerId], references: [id], onDelete: SetNull)

  // Market: what kind of piece, and the owner's open ask (display-only
  // until on-platform checkout exists).
  category         String @default("sneakers") // sneakers | apparel | accessories
  size             String? // e.g. "US 10.5", "L", "7 3/8" — buyers need this
  askingPriceCents Int?

  sales       Sale[]
  offers      Offer[]
  outfitItems OutfitItem[]
  ratings     DesignRating[]

  battlesAsA Battle[] @relation("battleSubA")
  battlesAsB Battle[] @relation("battleSubB")
  battlesWon Battle[] @relation("battleWinner")
  votes      Vote[]

  tournamentsWon Tournament[]      @relation("tournamentChampion")
  matchesAsA     TournamentMatch[] @relation("matchSubA")
  matchesAsB     TournamentMatch[] @relation("matchSubB")
}

model ArtistProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String   @unique
  displayName String
  bio         String?
  instagram   String?
  city        String?
  portfolioUrl String?
  // Fan accounts are instant; artist accounts are reviewed (payout
  // rails later require vetted identities). Existing/seed artists
  // default APPROVED; applications are created PENDING.
  status      String   @default("APPROVED") // PENDING | APPROVED | REJECTED
  // Subscription groundwork: everyone rides FREE until billing opens.
  plan      String @default("FREE") // FREE | PRO
  viewCount Int    @default(0) // raw public page views (own visits excluded)
  invitedAt DateTime? // last outreach email sent from the admin panel
  // Recruiting pipeline for pre-loaded pages: NEW (never touched) →
  // CONTACTED (comment/DM sent) → IN_TALKS (they replied) → INVITED
  // (claim link sent). Claimed pages leave the board entirely.
  outreachStage String  @default("NEW")
  outreachNotes String?
  createdAt   DateTime @default(now())

  submissions Submission[]
  followers   ArtistFollow[]
  claims      ArtistClaim[]
  feedPosts   FeedPost[]
}

// BETA (admin-only): Group Scout. Facebook groups worth pitching —
// tracked by hand (no ToS-breaking automation), each with a tagged
// link so Traffic Pulse and GA show which group actually converts.
model GroupLead {
  id        String   @id @default(cuid())
  name      String
  url       String?
  adminName String?
  members   String? // free text, e.g. "12K"
  stage     String   @default("NEW") // NEW | CONTACTED | IN_TALKS | POSTED
  notes     String?
  campaign  String   @unique // utm_campaign slug for the tagged link
  createdAt DateTime @default(now())
}

// BETA (admin-only): Store Scout. Local shoe stores prospected by zip
// code — the targets are stores with NO website, pitched a free
// "Heat Chart Verified Store" page. Pipeline: SCOUTED (found) →
// QUALIFIED (researched + email found) → INVITED → JOINED | PASSED.
// Nothing here is public yet; the model carries what a public store
// page will need when this graduates from beta.
model StoreLead {
  id          String  @id @default(cuid())
  placeId     String? @unique // Google Place id — dedupes rescans
  name        String
  address     String?
  zip         String?
  phone       String?
  mapsUrl     String?
  website     String? // null = the whole point
  rating      Float?
  reviewCount Int?

  // Brand research, filled in by hand before the invite goes out
  email      String?
  instagram  String?
  specialty  String? // e.g. "consignment + customs", "kids exclusives"
  notes      String?

  status    String    @default("SCOUTED") // SCOUTED | QUALIFIED | INVITED | JOINED | PASSED
  invitedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([status, createdAt])
  @@index([zip])
}

// Every outbound purchase click, logged before the 302 — the receipts
// behind affiliate revenue and retailer negotiations. Same privacy
// posture as PageView: bot-filtered, daily-rotating visitor hash.
model OutboundClick {
  id          String   @id @default(cuid())
  merchant    String // stockx | goat | ebay | nike | ...
  url         String // final URL after tagging
  ref         String? // where on-site it came from: article slug, "drops", "shop"
  visitorHash String
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([merchant, createdAt])
}

// First-party, cookieless traffic analytics. One row per pageview.
// visitorHash is an HMAC of (ip, user-agent, UTC day) — it rotates
// daily and the raw IP is never stored, so uniques can be counted
// without cookies, consent banners, or cross-site tracking.
model PageView {
  id           String   @id @default(cuid())
  path         String
  source       String   @default("direct") // utm_source, else mapped referrer, else "direct"
  medium       String?
  campaign     String?
  referrerHost String?
  device       String   @default("desktop") // mobile | desktop
  visitorHash  String
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([source, createdAt])
  @@index([visitorHash, createdAt])
}

// The Rate game: one design, one score out of five flames. Feeds each
// fan's taste profile and every piece's community rating.
model DesignRating {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  stars        Int // 1–5 flames
  createdAt    DateTime   @default(now())

  @@unique([submissionId, userId])
  @@index([submissionId])
}

// A look assembled from pieces. HOUSE outfits are admin-curated from
// the league's best; FAN outfits are built by members from pieces they
// actually own. One open league — house fits and fan fits battle in
// the same pool; kind only labels provenance on the card.
model Outfit {
  id        String   @id @default(cuid())
  name      String
  kind      String   @default("HOUSE") // HOUSE | FAN
  ownerId   String?
  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  items      OutfitItem[]
  battlesAsA OutfitBattle[] @relation("obA")
  battlesAsB OutfitBattle[] @relation("obB")
  battlesWon OutfitBattle[] @relation("obWinner")
}

model OutfitItem {
  id           String     @id @default(cuid())
  outfitId     String
  outfit       Outfit     @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([outfitId, submissionId])
}

model OutfitBattle {
  id     String  @id @default(cuid())
  title  String?
  league String  @default("HOUSE") // HOUSE | FAN
  status String  @default("ACTIVE") // ACTIVE | COMPLETED

  outfitAId String
  outfitA   Outfit @relation("obA", fields: [outfitAId], references: [id], onDelete: Cascade)
  outfitBId String
  outfitB   Outfit @relation("obB", fields: [outfitBId], references: [id], onDelete: Cascade)
  winnerId  String?
  winner    Outfit? @relation("obWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  endsAt    DateTime
  createdAt DateTime @default(now())

  votes OutfitVote[]
}

model OutfitVote {
  id       String       @id @default(cuid())
  battleId String
  battle   OutfitBattle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  outfitId String
  userId   String
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([battleId, userId])
  @@index([battleId, outfitId])
}

// A real-world artist asserting ownership of a pre-loaded page. Sits
// PENDING in the admin queue; approving relinks the page to their
// account and sends the password-setting claim link.
model ArtistClaim {
  id       String        @id @default(cuid())
  artistId String
  artist   ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)

  name        String
  email       String
  socialProof String? // IG handle / shop link that proves it's them
  message     String?
  // Seller verification — PRIVATE, admin eyes only, never rendered on
  // any public page. Street address required (no P.O. Boxes) so the
  // league knows its sellers are real.
  phone        String?
  businessName String?
  addressLine  String?
  city         String?
  state        String?
  zip          String?
  status      String  @default("PENDING") // PENDING | APPROVED | REJECTED

  createdAt DateTime @default(now())

  @@index([artistId, status])
}

model ArtistFollow {
  id        String   @id @default(cuid())
  artistId  String
  artist    ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([artistId, userId])
}

model Battle {
  id       String    @id @default(cuid())
  title    String?
  status   String    @default("ACTIVE") // ACTIVE | COMPLETED
  startsAt DateTime  @default(now())
  endsAt   DateTime
  createdAt DateTime @default(now())

  subAId String
  subA   Submission @relation("battleSubA", fields: [subAId], references: [id])
  subBId String
  subB   Submission @relation("battleSubB", fields: [subBId], references: [id])

  winnerId String?
  winner   Submission? @relation("battleWinner", fields: [winnerId], references: [id])

  votes Vote[]
  tournamentMatch TournamentMatch?
}

// Posts in The Feed on the home page. artistId null = the house
// (admin Broadcast); set = an approved artist posting from their
// Studio. Fans react, comment, and share — they don't post.
model FeedPost {
  id        String   @id @default(cuid())
  body      String
  imageUrl  String?
  linkUrl   String?
  linkLabel String?
  pinned    Boolean  @default(false)
  artistId  String?
  artist    ArtistProfile? @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  reactions FeedReaction[]
  comments  FeedComment[]
}

// One flame per fan per post.
model FeedReaction {
  id        String   @id @default(cuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model FeedComment {
  id        String   @id @default(cuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

model Tournament {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  size      Int // 4 | 8 | 16 entrants, single elimination
  status    String   @default("ACTIVE") // ACTIVE | COMPLETED
  // Talent level, like rec-league divisions: OPEN (anyone) |
  // RISING (up-and-comers) | ELITE (invitational heavyweights).
  division  String   @default("OPEN")
  // Category wall: a bracket only ever holds one piece category —
  // sneakers | apparel | headwear | accessories. Hats never face shoes.
  category  String   @default("sneakers")
  prize     String?
  roundDays Int      @default(3)
  createdAt DateTime @default(now())

  championId String?
  champion   Submission? @relation("tournamentChampion", fields: [championId], references: [id])

  matches TournamentMatch[]
}

model TournamentMatch {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        Int // 1-based; final round = log2(size)
  position     Int // 0-based slot within the round
  // Round-1 seed numbers (1 = top seed), shown on the bracket.
  seedA        Int?
  seedB        Int?

  battleId String? @unique
  battle   Battle? @relation(fields: [battleId], references: [id])

  subAId String?
  subA   Submission? @relation("matchSubA", fields: [subAId], references: [id])
  subBId String?
  subB   Submission? @relation("matchSubB", fields: [subBId], references: [id])

  winnerId String?

  @@unique([tournamentId, round, position])
}

model Vote {
  id           String   @id @default(cuid())
  battleId     String
  battle       Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  voterKey     String // the voting user's id (or a seed key for demo votes)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@unique([battleId, voterKey])
  @@index([battleId, submissionId])
}

// ---------- Accounts & auth (NextAuth models + profile fields) ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null for OAuth-only accounts

  // Profile / contact info (the "Sneaker Passport")
  phone              String?
  city               String?
  shoeSize           String?
  favoriteSilhouette String?
  favoriteBrands     String? // comma-separated, e.g. "Jordan, Nike, New Balance"
  styleInterests     String? // comma-separated, e.g. "Retro, Customs, Streetwear"
  instagram          String?
  marketingOptIn     Boolean @default(false)

  // Quiz economy
  credits         Int     @default(0) // purchased strikes
  freeStrikesDate String? // YYYY-MM-DD the free-strike counter applies to
  freeStrikesUsed Int     @default(0)

  createdAt DateTime @default(now())

  accounts       Account[]
  sessions       Session[]
  votes          Vote[]
  quizRuns       QuizRun[]
  creditTxns     CreditTransaction[]
  quizAnswers    QuizAnswer[]
  giveawayEntries GiveawayEntry[]
  giveawaysWon   Giveaway[]          @relation("giveawayWinner")
  artistProfile  ArtistProfile?
  artistFollows  ArtistFollow[]

  // Fan collector identity — public closet URL, minted on first piece.
  collectorSlug String?      @unique
  ownedPieces   Submission[] @relation("ownedPieces")

  salesSold   Sale[] @relation("salesSold")
  salesBought Sale[] @relation("salesBought")
  offers      Offer[]
  outfits     Outfit[]
  outfitVotes OutfitVote[]
  designRatings DesignRating[]
  feedReactions FeedReaction[]
  feedComments  FeedComment[]
}

// A buyer's standing offer on a piece — the demand side of the price
// index. No money moves on-platform: accepting an offer creates a
// PENDING Sale to the buyer's email, and the existing claim flow
// (buyer confirms from their own account) completes the hand-off.
model Offer {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  buyerId String
  buyer   User   @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  amountCents Int
  status      String   @default("OPEN") // OPEN | ACCEPTED | DECLINED | WITHDRAWN
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([submissionId, status])
}

// Off-platform sale record (no payment rails involved). Created by the
// seller, PENDING until the buyer claims it from their own account —
// then ownership transfers. Verified badge requires evidence (receipt /
// payment screenshot) or an admin override.
model Sale {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  sellerId String
  seller   User   @relation("salesSold", fields: [sellerId], references: [id], onDelete: Cascade)

  buyerEmail String
  buyerId    String?
  buyer      User?   @relation("salesBought", fields: [buyerId], references: [id], onDelete: SetNull)

  priceCents  Int
  soldAt      DateTime @default(now())
  note        String?
  evidenceUrl String? // uploaded receipt / payment screenshot

  status     String  @default("PENDING") // PENDING | CONFIRMED
  verified   Boolean @default(false)
  verifiedBy String? // "evidence" | "admin"

  createdAt DateTime @default(now())
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PasswordResetToken {
  token     String   @id
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())
}

// ---------- Quiz game & giveaway ----------

model QuizQuestion {
  id          String  @id @default(cuid())
  question    String
  options     String // JSON array of 4 strings
  answerIndex Int
  difficulty  Int     @default(1) // 1 easy, 2 medium, 3 hard
  category    String  @default("history")
  explanation String?
  active      Boolean @default(true)
  // Culture questions born from articles — the feed links back to the
  // story so people can read up before (or after) they answer.
  articleId   String?
  article     Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  answers QuizAnswer[]
}

// The Culture IQ ledger: one row per user per question, forever. A
// wrong answer can be cleared with 1 credit — the question is then
// burned for that user: no IQ penalty, but never asked again and the
// points can never be re-earned.
model QuizAnswer {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  correct    Boolean
  cleared    Boolean      @default(false)
  source     String       @default("feed") // feed | quiz
  createdAt  DateTime     @default(now())

  @@unique([userId, questionId])
}

model QuizRun {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionIds  String // JSON array, server-chosen order
  currentIndex Int       @default(0)
  correctCount Int       @default(0)
  wrongCount   Int       @default(0)
  // True once any purchased strike is spent in this run. Paid runs
  // count for the leaderboard but NEVER earn giveaway entries — paying
  // must not affect prize odds (sweepstakes law).
  usedPaidStrikes Boolean @default(false)
  status       String    @default("ACTIVE") // ACTIVE | NEEDS_CREDITS | WON | ABANDONED | OUT_OF_QUESTIONS
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
}

model CreditTransaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta           Int
  reason          String // purchase | strike | admin
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())
}

model Giveaway {
  id          String   @id @default(cuid())
  title       String
  prize       String
  description String?
  endsAt      DateTime
  status      String   @default("ACTIVE") // ACTIVE | DRAWN | CLOSED
  winnerId    String?
  winner      User?    @relation("giveawayWinner", fields: [winnerId], references: [id])
  createdAt   DateTime @default(now())

  entries GiveawayEntry[]
}

model GiveawayEntry {
  id         String   @id @default(cuid())
  giveawayId String
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source     String   @default("quiz") // quiz | manual
  createdAt  DateTime @default(now())
}

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String // doubles as the meta description — keep under ~160 chars
  content     String // markdown
  coverImage  String?
  tags        String? // comma-separated
  status      String    @default("DRAFT") // DRAFT | PUBLISHED
  publishedAt DateTime?
  // Drop calendar (free, no paywall): when the release drops and where
  // to enter its raffle. Articles with dropAt appear on /drops.
  dropAt      DateTime?
  raffleUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  cultureQuestions QuizQuestion[]
}

model Product {
  id           String  @id @default(cuid())
  // Stable key for the seed top-up: curated slate products upsert by
  // slug (create-only — admin edits are never overwritten on deploy).
  // Admin-created products have no slug and are never touched.
  slug         String? @unique
  name         String
  merchant     String
  category     String // marketplace | retail | customization | cleaning | accessories
  blurb        String?
  price        String?
  imageUrl     String?
  affiliateUrl String
  featured     Boolean @default(false)
  sortOrder    Int     @default(0)
  createdAt    DateTime @default(now())
}
